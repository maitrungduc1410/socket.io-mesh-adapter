{
  "name": "socket.io-mesh-adapter",
  "version": "2.0.0",
  "displayName": "SocketIO Mesh Adapter",
  "description": "The first adapter that truly scales your SocketIO app horizontally 🚀",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "socket.io-mesh-adapter": "./dist/discovery/discovery-server.js",
    "discovery-server": "./dist/discovery/discovery-server.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "DEBUG=socket.io-mesh-adapter:* tsx watch server.ts",
    "dev1": "cross-env DEBUG=socket.io-mesh-adapter:* PORT=3001 MESH_WS_PORT=4001 tsx watch server.ts",
    "dev:discovery": "DEBUG=socket.io-mesh-adapter:* tsx watch src/discovery/discovery-server.ts",
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "socket.io",
    "mesh",
    "adapter",
    "discovery",
    "server",
    "scale",
    "mesh adapter",
    "horizontal scaling",
    "socket.io adapter",
    "socket.io mesh",
    "socket.io horizontal scaling",
    "socket.io mesh adapter"
  ],
  "license": "MIT",
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "debug": "^4.4.3",
    "express": "^5.1.0",
    "prom-client": "^15.1.3",
    "socket.io-adapter": "^2.5.6",
    "ws": "^8.20.0"
  },
  "peerDependencies": {
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/debug": "^4.1.13",
    "@types/express": "^5.0.1",
    "@types/node": "^25.6.2",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.5",
    "cross-env": "^10.1.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "homepage": "https://github.com/maitrungduc1410/socket.io-mesh-adapter",
  "author": "maitrungduc1410@gmail.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/maitrungduc1410/socket.io-mesh-adapter.git"
  },
  "bugs": {
    "url": "https://github.com/maitrungduc1410/socket.io-mesh-adapter/issues"
  }
}
